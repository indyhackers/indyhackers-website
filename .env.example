# None required for `npm run dev` — MSW mocks PocketBase and Google Calendar in dev.

# Set to false to talk to real PocketBase on localhost:8090 (via Vite proxy). Requires PocketBase running.
# Use `npm run dev:backend` as shorthand. Default: MSW mocks all PocketBase API calls in dev.
VITE_USE_MSW=true

# Google Calendar API (Vite / frontend)
# Optional — live Google Calendar fetches (homepage events, /events export). MSW mocks in dev.
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable the Google Calendar API in your Google Cloud project
VITE_GOOGLE_CALENDAR_API_KEY=your_api_key_here

# --- PocketBase server-side (set on the `pocketbase` container, not Vite) ---
# Production: `docker run --env-file=.env`. Local docker-compose: add under service `environment:`.
# Optional — base URL used to build links in outgoing emails (e.g. the self-service job
# management link). Falls back to PocketBase Settings > Application URL if unset.
SITE_URL=https://indyhackers.com
# Optional — where new-job moderator notifications are sent (falls back to the SMTP sender).
JOB_NOTIFY_EMAIL=
# Optional Slack incoming webhook — pings for new-job notifications and pending
# Slack-invite requests.
SLACK_WEBHOOK_URL=

# --- Slack join page (/slack) + invite approval queue ---
# Read by the PocketBase backend (pb/hooks/slack.pb.js), NOT the Vite frontend.
# Slack token with admin scope + the *.slack.com subdomain are required to send
# invites. Without RECAPTCHA_SECRET the captcha check is skipped (dev only) —
# set it in production to prevent invite spam.
# SLACK_API_TOKEN=xoxp-...
# SLACK_SUBDOMAIN=indyhackers
# reCAPTCHA v3 (invisible, score-based) — NOT v2. Create a v3 key at
# https://www.google.com/recaptcha/admin/create
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET=
# RECAPTCHA_MIN_SCORE=0.5        # below this, requests go to the review queue
# Where pending-request notifications go (falls back to JOB_NOTIFY_EMAIL, then sender):
# SLACK_REVIEW_EMAIL=board@indyhackers.org
# SLACK_AUTOAPPROVE=on          # "off" sends every request to the review queue
# SLACK_RATE_PER_HOUR=5         # max invite requests per IP per hour

# --- Google login (OAuth2) ---
# Read by pb/hooks/oauth.pb.js; configures the Google provider at startup.
# Google Cloud OAuth client redirect URI must be:
#   https://<your-domain>/api/oauth2-redirect
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Google Calendar -> PocketBase sync (`sync-calendar` command / hourly cron) ---
# Required for calendar sync — Google API key
GOOGLE_API_KEY=
# Required for calendar sync — Google Calendar ID
GOOGLE_CALENDAR_ID=
# Optional for calendar sync — days ahead to sync (default: 90)
CALENDAR_SYNC_WINDOW_DAYS=
